---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const bookingUrl = "https://www.doctolib.de/praxis/luebeck/physio-one-luebeck";
---

<Base title="Kontakt | Physio One Lübeck" description="Physio One Lübeck — Mengstraße 40, 23552 Lübeck. Termine online über Doctolib oder telefonisch: 0451 160 866 40.">
  <Header />

  <section class="section page-header">
    <div class="container">
      <h1>Kontakt &amp; Anfahrt</h1>
      <p class="page-header__subtitle">So finden und erreichen Sie uns in der Lübecker Innenstadt.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Infos -->
        <div class="contact-info">
          <div class="info-block">
            <h2>Kontakt</h2>
            <p>
              <strong>Telefon:</strong> <a href="tel:+4945116086640">0451 160 866 40</a><br />
              <strong>E-Mail:</strong> <a href="mailto:info@luebeck-physio.de">info@luebeck-physio.de</a><br />
              <strong>WhatsApp:</strong> <a href="https://wa.me/4917640471528" target="_blank" rel="noopener">Nachricht senden</a>
            </p>
          </div>

          <div class="info-block">
            <h2>Adresse</h2>
            <p>
              Physio One<br />
              Mengstraße 40<br />
              23552 Lübeck
            </p>
          </div>

          <div class="info-block">
            <h2>Öffnungszeiten</h2>
            <table class="hours-table">
              <tr><td>Montag &ndash; Freitag</td><td>7:30 &ndash; 19:00 Uhr</td></tr>
              <tr><td>Samstag</td><td>7:30 &ndash; 19:00 Uhr</td></tr>
              <tr><td>Sonntag</td><td>Geschlossen</td></tr>
            </table>
          </div>

          <div class="info-block">
            <h2>Termin buchen</h2>
            <p>Am schnellsten online über Doctolib — rund um die Uhr.</p>
            <a href={bookingUrl} target="_blank" rel="noopener" class="btn btn--primary">Online-Termin buchen</a>
          </div>
        </div>

        <!-- Karte -->
        <div class="contact-map" id="map-container">
          <div class="map-placeholder" id="map-placeholder">
            <p>Karte wird geladen...</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <h2 class="text-center">Anfahrt &amp; Parken</h2>
      <div class="parking-grid">
        <div class="parking-card card">
          <h3>Praxis-Parkplätze</h3>
          <p>Direkt an der Praxis stehen Parkplätze zur Verfügung. Geben Sie <strong>Blockquerstraße 28</strong> in Ihr Navigationssystem ein.</p>
        </div>
        <div class="parking-card card">
          <h3>Marienparkhaus</h3>
          <p>Ca. <strong>2 Gehminuten</strong> entfernt. Ideal bei voller Praxis-Parkfläche.</p>
        </div>
        <div class="parking-card card">
          <h3>MUK-Parkplätze</h3>
          <p>Parkplätze an der Musik- und Kongresshalle, etwa <strong>5 Gehminuten</strong> entfernt.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script is:inline>
  function initMap() {
    if (!document.querySelector('link[href*="leaflet.css"]')) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
      link.crossOrigin = '';
      document.head.appendChild(link);
    }

    var script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
    script.crossOrigin = '';
    script.onload = function () {
      var container = document.getElementById('map-placeholder');
      container.innerHTML = '';
      container.id = 'map';
      container.style.height = '100%';
      container.style.minHeight = '400px';
      container.style.borderRadius = '8px';

      var map = L.map('map').setView([53.8655, 10.6866], 16);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(map);

      L.marker([53.8655, 10.6866])
        .addTo(map)
        .bindPopup('<strong>Physio One</strong><br>Mengstraße 40<br>23552 Lübeck')
        .openPopup();
    };
    document.head.appendChild(script);
  }

  if (document.readyState === 'complete') {
    initMap();
  } else {
    window.addEventListener('load', initMap);
  }
</script>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-2xl));
    padding-bottom: var(--space-xl);
    background: var(--color-black);
    color: var(--color-white);
  }

  .page-header h1 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .page-header__subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-lg);
    max-width: 600px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .info-block {
    margin-bottom: var(--space-lg);
  }

  .info-block h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }

  .info-block p {
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.8;
  }

  .hours-table {
    width: 100%;
    border-collapse: collapse;
  }

  .hours-table td {
    padding: 0.5rem 0;
    font-weight: 300;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-mid-gray);
  }

  .hours-table td:last-child {
    text-align: right;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .contact-map {
    min-height: 400px;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .map-placeholder {
    height: 400px;
    background: var(--color-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-placeholder p {
    color: var(--color-text-muted);
  }

  .parking-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .parking-card {
    text-align: center;
  }

  .parking-card h3 {
    margin-bottom: var(--space-xs);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .parking-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
