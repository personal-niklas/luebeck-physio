---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const bookingUrl = "https://www.doctolib.de/praxis/luebeck/physio-one";
---

<Base title="Kontakt | Physio One Lübeck" description="Physio One Lübeck — Mengstraße 40, 23552 Lübeck. Termine online über Doctolib oder telefonisch: 0451 160 866 40.">
  <Header />

  <section class="section page-header">
    <div class="container">
      <h1>Kontakt & <span class="text-accent">Anfahrt</span></h1>
      <p class="page-header__subtitle">So finden und erreichen Sie uns in der Lübecker Innenstadt.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Infos -->
        <div class="contact-info">
          <div class="info-block">
            <h2>Kontakt</h2>
            <p>
              <strong>Telefon:</strong> <a href="tel:+4945116086640">0451 160 866 40</a><br />
              <strong>E-Mail:</strong> <a href="mailto:info@luebeck-physio.de">info@luebeck-physio.de</a><br />
              <strong>WhatsApp:</strong> <a href="https://wa.me/4917640471528" target="_blank" rel="noopener noreferrer">Nachricht senden</a>
            </p>
          </div>

          <div class="info-block">
            <h2>Adresse</h2>
            <p>
              Physio One<br />
              Mengstraße 40<br />
              23552 Lübeck
            </p>
          </div>

          <div class="info-block">
            <h2>Öffnungszeiten</h2>
            <table class="hours-table">
              <tr><td>Montag &ndash; Freitag</td><td>7:30 &ndash; 19:00 Uhr</td></tr>
            </table>
            <p class="hours-note">Telefonische Sprechzeiten können abweichen. Hinterlassen Sie gerne eine Nachricht — wir rufen zeitnah zurück.</p>
          </div>

          <div class="info-block info-block--dogs">
            <h2>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-inline" aria-hidden="true"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg>
              Hunde willkommen
            </h2>
            <p>Ihr Hund darf Sie gerne in die Praxis begleiten. Unser Praxishund Teddy freut sich auf vierbeinigen Besuch.</p>
          </div>

          <div class="info-block">
            <h2>Termin buchen</h2>
            <p>Am schnellsten online über Doctolib — rund um die Uhr.</p>
            <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary">Online-Termin buchen</a>
          </div>
        </div>

        <!-- Karte -->
        <div class="contact-map" id="map-container">
          <div class="map-placeholder" id="map-placeholder">
            <p>Karte wird geladen...</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light" id="kontaktformular">
    <div class="container">
      <h2 class="text-center">Nachricht schreiben</h2>
      <p class="form-subtitle text-center">Sie haben eine Frage oder möchten einen Termin anfragen? Schreiben Sie uns — wir melden uns zeitnah.</p>
      <form class="contact-form" id="contact-form" action="/api/contact" method="POST">
        <!-- Honeypot (Spam-Schutz, unsichtbar) -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="form-row">
          <div class="form-group">
            <label for="name">Name *</label>
            <input type="text" id="name" name="name" required placeholder="Ihr Name" />
          </div>
          <div class="form-group">
            <label for="email">E-Mail *</label>
            <input type="email" id="email" name="email" required placeholder="ihre@email.de" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="phone">Telefon</label>
            <input type="tel" id="phone" name="phone" placeholder="Optional" />
          </div>
          <div class="form-group">
            <label for="subject">Betreff</label>
            <select id="subject" name="subject">
              <option value="Terminanfrage">Terminanfrage</option>
              <option value="Allgemeine Frage">Allgemeine Frage</option>
              <option value="Rezept-Frage">Frage zu Rezept / Verordnung</option>
              <option value="Feedback">Feedback</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="message">Nachricht *</label>
          <textarea id="message" name="message" rows="5" required placeholder="Ihre Nachricht an uns..."></textarea>
        </div>
        <!-- Cloudflare Turnstile (unsichtbarer Spam-Schutz) -->
        <div class="cf-turnstile" data-sitekey="0x4AAAAAAACo02teqIuxED6jM" data-theme="light"></div>
        <button type="submit" class="btn btn--primary">Nachricht senden</button>
        <p class="form-hint">* Pflichtfelder. Ihre Daten werden nur zur Bearbeitung Ihrer Anfrage verwendet. <a href="/datenschutz/">Datenschutz</a></p>
      </form>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="text-center">Anfahrt &amp; Parken</h2>
      <div class="parking-grid">
        <div class="parking-card card">
          <h3>Praxis-Parkplätze</h3>
          <p>Direkt an der Praxis stehen Parkplätze zur Verfügung. Geben Sie <strong>Blockquerstraße 28</strong> in Ihr Navigationssystem ein.</p>
        </div>
        <div class="parking-card card">
          <h3>Marienparkhaus</h3>
          <p>Ca. <strong>2 Gehminuten</strong> entfernt. Ideal bei voller Praxis-Parkfläche.</p>
        </div>
        <div class="parking-card card">
          <h3>MUK-Parkplätze</h3>
          <p>Parkplätze an der Musik- und Kongresshalle, etwa <strong>5 Gehminuten</strong> entfernt.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script is:inline>
  // Error message display (from redirect ?error= param)
  (function() {
    var params = new URLSearchParams(window.location.search);
    var errorType = params.get('error');
    if (errorType) {
      var form = document.getElementById('contact-form');
      var msg = document.createElement('div');
      msg.className = 'form-error';
      if (errorType === 'captcha') {
        msg.innerHTML = '<p>Die Sicherheitsprüfung konnte nicht abgeschlossen werden. Bitte versuchen Sie es erneut.</p>';
      } else {
        msg.innerHTML = '<p>Ihre Nachricht konnte leider nicht gesendet werden. Bitte versuchen Sie es erneut oder rufen Sie uns an: <a href="tel:+4945116086640">0451 160 866 40</a></p>';
      }
      form.prepend(msg);
    }
  })();

  function initMap() {
    if (!document.querySelector('link[href*="leaflet.css"]')) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
      link.crossOrigin = '';
      document.head.appendChild(link);
    }

    var script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
    script.crossOrigin = '';
    script.onload = function () {
      var container = document.getElementById('map-placeholder');
      container.innerHTML = '';
      container.id = 'map';
      container.style.height = '100%';
      container.style.minHeight = '400px';
      container.style.borderRadius = '8px';

      var map = L.map('map').setView([53.8655, 10.6866], 16);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(map);

      L.marker([53.8655, 10.6866])
        .addTo(map)
        .bindPopup('<strong>Physio One</strong><br>Mengstraße 40<br>23552 Lübeck')
        .openPopup();
    };
    document.head.appendChild(script);
  }

  if (document.readyState === 'complete') {
    initMap();
  } else {
    window.addEventListener('load', initMap);
  }
</script>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-2xl));
    padding-bottom: var(--space-xl);
    background: var(--color-black);
    color: var(--color-white);
  }

  .page-header h1 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .page-header .text-accent {
    color: var(--color-accent);
  }

  .page-header__subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-lg);
    max-width: 600px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .info-block {
    margin-bottom: var(--space-lg);
  }

  .info-block h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }

  .info-block p {
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.8;
  }

  .hours-table {
    width: 100%;
    border-collapse: collapse;
  }

  .hours-table td {
    padding: 0.5rem 0;
    font-weight: 300;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-mid-gray);
  }

  .hours-table td:last-child {
    text-align: right;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .hours-note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    font-weight: 300;
    line-height: 1.6;
  }

  .contact-map {
    min-height: 400px;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .map-placeholder {
    height: 400px;
    background: var(--color-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-placeholder p {
    color: var(--color-text-muted);
  }

  .parking-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .parking-card {
    text-align: center;
  }

  .parking-card h3 {
    margin-bottom: var(--space-xs);
  }

  .form-subtitle {
    max-width: 600px;
    margin: 0 auto var(--space-xl);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    font-weight: 300;
  }

  .contact-form {
    max-width: 700px;
    margin: 0 auto;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-group {
    margin-bottom: var(--space-md);
  }

  .form-group label {
    display: block;
    font-family: var(--font-headline);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    border: 1px solid var(--color-mid-gray);
    border-radius: var(--border-radius);
    background: var(--color-white);
    color: var(--color-text-primary);
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form .btn {
    width: 100%;
  }

  .form-hint {
    margin-top: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
  }

  .form-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: var(--border-radius);
    padding: 1rem 1.25rem;
    margin-bottom: var(--space-lg);
  }

  .form-error p {
    color: #991b1b;
    font-size: var(--text-sm);
    font-weight: 400;
    margin: 0;
  }

  .form-error a {
    color: #991b1b;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .parking-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
