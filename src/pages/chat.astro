---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base title="KI-Assistent | Physio One Lübeck" description="Stellen Sie Ihre Fragen zu Physiotherapie, Terminen und Behandlungen — unser KI-Assistent antwortet sofort.">
  <Header />

  <section class="section page-header">
    <div class="container">
      <h1>KI-<span class="text-accent">Assistent</span></h1>
      <p class="page-header__subtitle">Fragen zu Physiotherapie, Terminen oder Behandlungen? Unser KI-Assistent hilft Ihnen sofort weiter.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="chat-wrapper">
        <div class="chat-info">
          <div class="chat-info__badge">24/7 verfügbar</div>
          <p>Unser KI-Assistent beantwortet häufige Fragen rund um Physiotherapie, unsere Leistungen und die Terminbuchung. Für eine persönliche Beratung erreichen Sie uns telefonisch unter <a href="tel:+4945116086640">0451 160 866 40</a> oder per <a href="https://wa.me/4917640471528">WhatsApp</a>.</p>
        </div>
        <div class="chat-container" id="chat-widget"></div>
      </div>
    </div>
  </section>

  <Footer />

  <link rel="stylesheet" href="https://cdn.insighto.ai/chat-widget-v2/style.css" />
  <script is:inline src="https://cdn.insighto.ai/chat-widget-v2/script.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      new ChatWidget({
        widgetId: "01993dc7-4efb-7ac2-9314-df4f40a2f339",
        deployType: "inline",
        containerElement: document.getElementById("chat-widget"),
      }).init();
    });
  </script>
</Base>

<style>
  .chat-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .chat-info {
    margin-bottom: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-alt, #f5f5f5);
    border-radius: 12px;
    border-left: 4px solid var(--color-accent, #ea5d1c);
  }

  .chat-info__badge {
    display: inline-block;
    background: var(--color-accent, #ea5d1c);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }

  .chat-info p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #333;
  }

  .chat-info a {
    color: var(--color-accent, #ea5d1c);
    text-decoration: none;
    font-weight: 600;
  }

  .chat-info a:hover {
    text-decoration: underline;
  }

  .chat-container {
    width: 100%;
    min-height: 600px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    border: 1px solid #e0e0e0;
  }

  @media (max-width: 768px) {
    .chat-container {
      min-height: 500px;
      border-radius: 8px;
    }
  }
</style>
