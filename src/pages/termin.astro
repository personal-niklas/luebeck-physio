---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const bookingUrl = "https://www.doctolib.de/praxis/luebeck/physio-one";
---

<Base title="Termin buchen | Physio One Lübeck" description="Buchen Sie Ihren Physiotherapie-Termin bei Physio One in Lübeck — online über Doctolib, telefonisch oder per WhatsApp.">
  <Header />

  <section class="section page-header">
    <div class="container">
      <h1>Termin <span class="text-accent">buchen</span></h1>
      <p class="page-header__subtitle">Schnell und unkompliziert — online, telefonisch oder per WhatsApp.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="booking-grid">

        <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="booking-card booking-card--primary">
          <div class="booking-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h2>Online buchen</h2>
          <p>Wählen Sie Ihren Wunschtermin direkt über Doctolib — rund um die Uhr verfügbar.</p>
          <span class="booking-card__cta">Termin auf Doctolib buchen &rarr;</span>
        </a>

        <a href="tel:+4945116086640" class="booking-card">
          <div class="booking-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h2>Anrufen</h2>
          <p>Mo &ndash; Fr, 7:30 &ndash; 19:00 Uhr</p>
          <span class="booking-card__cta">0451 160 866 40</span>
        </a>

        <a href="https://wa.me/4917640471528" target="_blank" rel="noopener noreferrer" class="booking-card">
          <div class="booking-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <h2>WhatsApp</h2>
          <p>Schreiben Sie uns eine Nachricht — wir antworten zeitnah.</p>
          <span class="booking-card__cta">WhatsApp öffnen &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <h2 class="text-center">Gut zu wissen</h2>
      <div class="info-grid">
        <div class="info-card card">
          <h3>Erster Termin</h3>
          <p>Bringen Sie bitte Ihre <strong>Verordnung (Rezept)</strong> mit und tragen Sie bequeme Kleidung.</p>
        </div>
        <div class="info-card card">
          <h3>Alle Kassen</h3>
          <p>Wir behandeln gesetzlich und privat versicherte Patienten sowie Selbstzahler. Alle gängigen Kassen werden akzeptiert.</p>
        </div>
        <div class="info-card card">
          <h3>Absage / Umbuchung</h3>
          <p>Bitte sagen Sie Ihren Termin mindestens <strong>24 Stunden vorher</strong> ab — über Doctolib, telefonisch oder per WhatsApp.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-2xl));
    padding-bottom: var(--space-xl);
    background: var(--color-black);
    color: var(--color-white);
  }

  .page-header h1 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .page-header .text-accent {
    color: var(--color-accent);
  }

  .page-header__subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-lg);
    max-width: 600px;
  }

  .booking-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .booking-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
    border-radius: var(--border-radius);
    border: 1px solid var(--color-mid-gray);
    background: var(--color-white);
    text-decoration: none;
    color: var(--color-text-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .booking-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .booking-card--primary {
    border-color: var(--color-accent);
    border-width: 2px;
    background: var(--color-white);
    color: var(--color-text-primary);
  }

  .booking-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .booking-card--primary .booking-card__icon {
    background: rgba(234, 93, 28, 0.1);
  }

  .booking-card h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
  }

  .booking-card p {
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: var(--space-md);
    flex: 1;
  }

  .booking-card__cta {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 700;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .info-card {
    text-align: center;
  }

  .info-card h3 {
    margin-bottom: var(--space-xs);
  }

  .info-card p {
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .booking-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
