---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const bookingUrl = "https://www.doctolib.de/praxis/luebeck/physio-one";
---

<Base title="Nachricht gesendet | Physio One Lübeck" description="Vielen Dank für Ihre Nachricht. Wir melden uns schnellstmöglich bei Ihnen." noindex={true}>
  <Header />

  <section class="danke-hero cross-pattern">
    <div class="container danke-hero__content">
      <div class="danke-check" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <h1>Nachricht <span class="text-accent">gesendet!</span></h1>
      <p class="danke-hero__sub">Vielen Dank für Ihre Anfrage. Wir melden uns zeitnah bei Ihnen — in der Regel innerhalb eines Werktages.</p>
    </div>
  </section>

  <section class="section danke-next">
    <div class="container">
      <h2 class="text-center">So geht es <span class="text-accent">weiter</span></h2>
      <div class="danke-steps">
        <div class="danke-step">
          <div class="danke-step__number">1</div>
          <div class="danke-step__content">
            <h3>Wir melden uns</h3>
            <p>Unser Team liest Ihre Nachricht und meldet sich per E-Mail oder Telefon bei Ihnen — meistens noch am selben Tag.</p>
          </div>
        </div>
        <div class="danke-step">
          <div class="danke-step__number">2</div>
          <div class="danke-step__content">
            <h3>Rezept bereithalten</h3>
            <p>Falls Sie eine ärztliche Verordnung haben, halten Sie diese bitte bereit. Ohne Rezept behandeln wir Sie gerne als Selbstzahler.</p>
          </div>
        </div>
        <div class="danke-step">
          <div class="danke-step__number">3</div>
          <div class="danke-step__content">
            <h3>Schneller geht's online</h3>
            <p>Möchten Sie nicht warten? Buchen Sie Ihren Termin direkt online — rund um die Uhr.</p>
            <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--small" style="margin-top: var(--space-sm);">Online-Termin buchen</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section danke-contact">
    <div class="container">
      <div class="danke-contact__box">
        <h3>Dringende Frage?</h3>
        <p>Rufen Sie uns einfach an — wir helfen Ihnen gerne weiter.</p>
        <div class="danke-contact__links">
          <a href="tel:+4945116086640" class="btn btn--primary">0451 160 866 40</a>
          <a href="mailto:info@luebeck-physio.de" class="btn btn--outline">info@luebeck-physio.de</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<!-- GTM Conversion Tracking -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'form_submission',
    form_name: 'kontaktformular',
    form_destination: 'info@luebeck-physio.de'
  });
</script>

<style>
  /* Hero */
  .danke-hero {
    position: relative;
    background: var(--color-black);
    color: var(--color-white);
    padding: calc(var(--header-height) + var(--space-3xl)) 0 var(--space-3xl);
    text-align: center;
    overflow: hidden;
  }

  .danke-hero__content {
    position: relative;
    z-index: 1;
  }

  .danke-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-white);
    margin-bottom: var(--space-lg);
  }

  .danke-hero h1 {
    color: var(--color-white);
    margin-bottom: var(--space-md);
  }

  .danke-hero .text-accent {
    color: var(--color-accent);
  }

  .danke-hero__sub {
    font-weight: 300;
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.7);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Next Steps */
  .danke-next h2 {
    margin-bottom: var(--space-2xl);
  }

  .danke-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 960px;
    margin: 0 auto;
  }

  .danke-step {
    text-align: center;
  }

  .danke-step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-black);
    color: var(--color-white);
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .danke-step h3 {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    text-transform: uppercase;
    color: var(--color-black);
    margin-bottom: var(--space-xs);
  }

  .danke-step p {
    font-weight: 300;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Contact Box */
  .danke-contact {
    padding-top: 0;
  }

  .danke-contact__box {
    background: var(--color-light-gray);
    border-radius: 12px;
    padding: var(--space-xl);
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .danke-contact__box h3 {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    text-transform: uppercase;
    color: var(--color-black);
    margin-bottom: var(--space-xs);
  }

  .danke-contact__box p {
    font-weight: 300;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .danke-contact__links {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .danke-steps {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .danke-step {
      display: flex;
      text-align: left;
      gap: var(--space-md);
      align-items: flex-start;
    }

    .danke-step__number {
      flex-shrink: 0;
    }

    .danke-contact__links {
      flex-direction: column;
    }

    .danke-contact__links .btn {
      width: 100%;
    }
  }
</style>
