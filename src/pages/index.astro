---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const bookingUrl = "https://www.doctolib.de/praxis/luebeck/physio-one";

const services = [
  {
    icon: "01",
    title: "Krankengymnastik",
    text: "Gezielte Bewegungstherapie bei Rückenschmerzen, Nackenverspannungen und Haltungsproblemen.",
    link: "/leistungen/krankengymnastik-luebeck/",
  },
  {
    icon: "02",
    title: "Gerätegestützte KG",
    text: "Training an medizinischen Geräten — ideal nach Verletzungen, Operationen oder zum gezielten Muskelaufbau.",
    link: "/leistungen/geraetegestuetzte-krankengymnastik-luebeck/",
  },
  {
    icon: "03",
    title: "Manuelle Lymphdrainage",
    text: "Sanfte Entstauungstherapie bei Lymphödemen, Schwellungen nach OPs oder schweren Beinen.",
    link: "/leistungen/manuelle-lymphdrainage-luebeck/",
  },
  {
    icon: "04",
    title: "Fango & Wärmetherapie",
    text: "Tiefenwärme gegen chronische Schmerzen und Muskelverhärtungen. Kältetherapie bei akuten Entzündungen.",
    link: "/leistungen/fango-waermetherapie-luebeck/",
  },
  {
    icon: "05",
    title: "Elektrotherapie",
    text: "Therapeutischer Strom zur Schmerzlinderung und Heilungsunterstützung — z.\u00A0B. bei Ischias oder Nervenschmerzen.",
    link: "/leistungen/elektrotherapie-luebeck/",
  },
  {
    icon: "06",
    title: "Massage",
    text: "Klassische Massagetherapie gegen Muskelverspannungen, stressbedingte Beschwerden und Kopfschmerzen.",
    link: "/leistungen/massage-luebeck/",
  },
];

const principles = [
  {
    letter: "O",
    title: "Optimal",
    text: "Für Ihre optimale Genesung und den bestmöglichen Aufbau Ihrer körperlichen Leistungsfähigkeit.",
  },
  {
    letter: "N",
    title: "Nachhaltig",
    text: "Für dauerhafte Ergebnisse, die weit über die reine Schmerzbehandlung hinausgehen.",
  },
  {
    letter: "E",
    title: "Engagiert",
    text: "Unser spezialisiertes Team aus Therapeuten und Trainern arbeitet engagiert Hand in Hand.",
  },
];

const reviews = [
  {
    text: "Ich war wegen eines Kapselrisses in Behandlung und habe mich von Anfang an gut aufgehoben gefühlt.",
    name: "Patient bei Google",
    stars: 5,
  },
  {
    text: "Das Team ist sehr freundlich, kompetent und nimmt sich viel Zeit.",
    name: "Patient bei Google",
    stars: 5,
  },
  {
    text: "Tolles Konzept mit Fachwissen auf dem besten und aktuellsten Stand.",
    name: "Patient bei Google",
    stars: 5,
  },
];

const faqs = [
  {
    q: "Brauche ich eine ärztliche Verordnung?",
    a: "Ja, für Behandlungen auf Kosten Ihrer Krankenkasse benötigen Sie eine gültige ärztliche Verordnung. Die Behandlung muss innerhalb von 28 Kalendertagen nach Ausstellung beginnen.",
  },
  {
    q: "Werden die Kosten von meiner Krankenkasse übernommen?",
    a: "Wir behandeln Patienten aller Krankenkassen. Die Kostenübernahme richtet sich nach Ihrer Kasse und Verordnung. Gesetzlich Versicherte tragen in der Regel eine Zuzahlung.",
  },
  {
    q: "Was soll ich zum ersten Termin mitbringen?",
    a: "Bitte bringen Sie Ihre ärztliche Verordnung, relevante medizinische Unterlagen, ein Handtuch und bequeme Kleidung mit.",
  },
  {
    q: "Wie kann ich einen Termin buchen?",
    a: "Am einfachsten über unseren Online-Kalender auf Doctolib — rund um die Uhr. Alternativ telefonisch während unserer Öffnungszeiten.",
  },
  {
    q: "Darf ich meinen Hund mitbringen?",
    a: "Ja, Hunde sind in unserer Praxis willkommen. Unser Praxishund Teddy freut sich auf vierbeinigen Besuch.",
  },
];
---

<Base title="Physiotherapie Lübeck Innenstadt | Physio One – Praxis für Krankengymnastik & Therapie" description="Physiotherapie in Lübeck: Krankengymnastik, KGG, Lymphdrainage, Fango & Massage bei Physio One. Alle Kassen. Praxis in der Mengstraße — jetzt online Termin buchen!">
  <Header />

  <!-- FAQPage Schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <!-- HERO -->
  <section class="hero">
    <picture>
      <source srcset="/images/hero-behandlung-mobile.webp" media="(max-width: 768px)" width="960" height="640" />
      <img src="/images/hero-behandlung.webp" alt="Physiotherapeut behandelt Patientin in der Physio One Praxis in Lübeck" class="hero__bg" width="1920" height="1280" loading="eager" fetchpriority="high" />
    </picture>
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="hero__label">One Way To Physical Health</p>
        <h1>Physiotherapie <span class="text-accent">in Lübeck</span></h1>
        <p class="hero__text">
          Weil Genesung mehr ist als nur Behandlung. Wir verbinden gezielte Physiotherapie mit individuellem Training — für dauerhafte Ergebnisse statt kurzfristiger Linderung.
        </p>
        <div class="hero__actions">
          <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary">Termin buchen</a>
          <a href="/leistungen/" class="btn btn--outline">Leistungen ansehen</a>
        </div>
        <p class="hero__kassen">Alle Krankenkassen &mdash; mit ärztlicher Verordnung</p>
      </div>
    </div>
  </section>

  <!-- KONZEPT -->
  <section class="section section--light" id="konzept">
    <div class="container text-center">
      <h2>Ihre Physiotherapie-Praxis <span class="text-accent">in der Lübecker Innenstadt</span></h2>
      <p class="section__subtitle">
        Kennen Sie das? Sie gehen zur Physiotherapie, fühlen sich danach kurz besser — doch im Alltag kehren die Beschwerden zurück. Bei uns endet Therapie nicht, wenn der Schmerz nachlässt. Wir machen Sie fit für die Belastungen des Lebens.
      </p>
    </div>
    <div class="container">
      <div class="principles stagger-in">
        {principles.map(p => (
          <div class="principle-card">
            <span class="principle-card__letter">{p.letter}</span>
            <h3 class="principle-card__title">{p.title}</h3>
            <p>{p.text}</p>
          </div>
        ))}
        <div class="principle-card principle-card--plus">
          <span class="principle-card__letter">+</span>
          <h3 class="principle-card__title">Physio One+</h3>
          <p>Optional: Mehr Behandlungszeit für intensivere Betreuung. Fragen Sie uns nach den Zusatzoptionen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LEISTUNGEN -->
  <section class="section" id="leistungen">
    <div class="container">
      <h2 class="text-center">Physiotherapie-Leistungen <span class="text-accent">bei Physio One</span></h2>
      <p class="section__subtitle text-center">Krankengymnastik, Gerätetraining, Lymphdrainage und mehr — alles aus einer Hand in Lübeck.</p>
      <div class="services-grid stagger-in">
        {services.map(s => (
          <a href={s.link} class="service-card card card-lift">
            <span class="service-card__number">{s.icon}</span>
            <h3>{s.title}</h3>
            <p set:html={s.text} />
            <span class="service-card__link">Mehr erfahren &rarr;</span>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top: var(--space-xl);">
        <a href="/leistungen/" class="btn btn--dark">Alle Leistungen im Detail</a>
      </div>
    </div>
  </section>

  <!-- QUIZ TEASER -->
  <section class="section section--light quiz-teaser">
    <div class="container text-center">
      <p class="quiz-teaser__eyebrow">Nicht sicher, welche Behandlung passt?</p>
      <h2>Finden Sie es in 4 Fragen <span class="text-accent">heraus</span></h2>
      <p class="quiz-teaser__desc">Unser Behandlungs-Check hilft Ihnen, die passende Therapie für Ihre Beschwerden zu finden — schnell und unverbindlich.</p>
      <a href="/fragebogen/" class="btn btn--primary">Behandlungs-Check starten</a>
    </div>
  </section>

  <!-- BEWERTUNGEN -->
  <section class="section section--dark" id="bewertungen">
    <div class="container text-center">
      <h2>Was unsere <span class="text-accent">Patienten</span> sagen</h2>
      <div class="rating">
        <span class="rating__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="rating__text">5.0 von 5 &mdash; basierend auf Google-Bewertungen</span>
      </div>
      <a href="https://www.google.com/maps/place/Physio+One" target="_blank" rel="noopener noreferrer" class="reviews-link">Alle Bewertungen auf Google ansehen &rarr;</a>
      <div class="reviews-grid stagger-in">
        {reviews.map(r => (
          <blockquote class="review-card">
            <p>&bdquo;{r.text}&ldquo;</p>
            <div class="review-card__footer">
              <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <cite class="review-card__name">{r.name}</cite>
            </div>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <h2 class="text-center">Häufige <span class="text-accent">Fragen</span></h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-item__question">{f.q}</summary>
            <p class="faq-item__answer">{f.a}</p>
          </details>
        ))}
      </div>
      <div class="text-center" style="margin-top: var(--space-lg);">
        <a href="/faq/" class="btn btn--outline">Alle Fragen ansehen</a>
      </div>
    </div>
  </section>

  <!-- PERSONAL TRAINING CROSS-LINK -->
  <section class="section section--light crosslink">
    <div class="container text-center">
      <h2>Auch <span class="text-accent">Personal Training</span> am gleichen Standort</h2>
      <p class="crosslink__text">
        Neben Physiotherapie bieten wir in der Mengstraße 40 auch individuelles Personal Training an — ob nach der Reha, für gezielten Muskelaufbau oder als Ausgleich zum Berufsalltag.
      </p>
      <a href="https://personaltrainingluebeck.de" target="_blank" rel="noopener" class="btn btn--dark">Zum Personal Training &rarr;</a>
    </div>
  </section>

  <InstagramFeed username="physio.one.hl" profileUrl="https://www.instagram.com/physio.one.hl/" />

  <!-- CTA -->
  <section class="section section--accent">
    <div class="container text-center">
      <h2>Bereit für den ersten <span class="text-accent">Schritt?</span></h2>
      <p class="cta-subtitle">
        Buchen Sie jetzt Ihren Termin — online oder telefonisch.
      </p>
      <div class="cta-actions">
        <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn btn--white">Termin buchen</a>
        <a href="tel:+4945116086640" class="btn btn--outline btn--outline-white">
          0451 160 866 40
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* --- Hero --- */
  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    background: #000;
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.35;
    z-index: 0;
  }

  .hero__content {
    max-width: 700px;
    position: relative;
    z-index: 1;
  }

  .hero__label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero h1 {
    color: var(--color-white);
    margin-bottom: var(--space-md);
  }

  .hero__text {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    max-width: 560px;
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .hero__kassen {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  /* --- Section Subtitle --- */
  .section__subtitle {
    max-width: 640px;
    margin: 0 auto var(--space-xl);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: 1.8;
  }

  /* --- Principles --- */
  .principles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .principle-card {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .principle-card__letter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--color-black);
    color: var(--color-white);
    font-family: var(--font-headline);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
  }

  .principle-card--plus .principle-card__letter {
    background-color: var(--color-accent);
  }

  .principle-card__title {
    margin-bottom: var(--space-xs);
  }

  /* --- Services Grid --- */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .service-card {
    text-align: center;
  }

  .service-card__number {
    display: block;
    font-family: var(--font-headline);
    font-size: var(--text-5xl);
    color: var(--color-accent);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .service-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .service-card h3 {
    margin-bottom: var(--space-xs);
  }

  .service-card__link {
    margin-top: auto;
    padding-top: var(--space-sm);
    font-family: var(--font-headline);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .service-card:hover .service-card__link {
    color: var(--color-accent-hover);
  }

  /* --- Rating --- */
  .rating {
    margin-bottom: var(--space-xl);
  }

  .rating__stars {
    display: block;
    font-size: var(--text-3xl);
    color: var(--color-accent);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-xs);
  }

  .rating__text {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    text-align: left;
  }

  .review-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .review-card p {
    color: rgba(255, 255, 255, 0.8);
    font-style: italic;
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: var(--space-sm);
  }

  .reviews-link {
    display: inline-block;
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    margin-bottom: var(--space-lg);
  }

  .reviews-link:hover {
    color: var(--color-accent);
  }

  .review-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .review-card__stars {
    color: var(--color-accent);
    font-size: var(--text-sm);
    letter-spacing: 0.05em;
  }

  .review-card__name {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-xs);
    font-style: normal;
  }

  /* --- FAQ --- */
  .faq-list {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-mid-gray);
    padding: var(--space-md) 0;
  }

  .faq-item__question {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    text-transform: uppercase;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
  }

  .faq-item__question::after {
    content: '+';
    font-size: var(--text-2xl);
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .faq-item[open] .faq-item__question::after {
    content: '\2212';
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__answer {
    padding-top: var(--space-sm);
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.7;
  }

  /* --- Quiz Teaser --- */
  .quiz-teaser__eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .quiz-teaser__desc {
    max-width: 520px;
    margin: 0 auto var(--space-lg);
    color: var(--color-text-muted);
    font-weight: 300;
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  /* --- CTA Section --- */
  .cta-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* --- Cross-Link --- */
  .crosslink__text {
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    color: var(--color-text-muted);
    font-weight: 300;
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  /* --- Responsive --- */
  @media (max-width: 1024px) {
    .principles {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
      padding-top: calc(var(--header-height) + var(--space-lg));
    }

    .services-grid,
    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .principles {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
    }

    .cta-actions {
      flex-direction: column;
      align-items: center;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: auto;
      padding-bottom: var(--space-xl);
    }

    .hero__text {
      font-size: var(--text-base);
    }

    .faq-item__question {
      font-size: var(--text-lg);
    }

    .faq-item__question::after {
      font-size: var(--text-xl);
    }
  }
</style>
