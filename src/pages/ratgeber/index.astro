    slug: "bandscheibenvorfall-symptome-behandlung",
    date: "2026-03-09",
    image: "/images/ratgeber-bandscheibenvorfall.webp",
    imageAlt: "Anatomisches Wirbelsäulenmodell in einer Physiotherapie-Praxis",
    tags: ["Rücken"],
  },
  {
    title: "ISG-Blockade — Übungen & Behandlung",
