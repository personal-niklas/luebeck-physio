  },
  {
    title: "Frozen Shoulder — Phasen, Behandlung & Übungen",
    excerpt: "Schultersteife verstehen: Die 3 Phasen, warum Physiotherapie entscheidend ist und welche Übungen helfen.",
    slug: "frozen-shoulder-behandlung-uebungen",
    date: "2026-03-09",
    image: "/images/ratgeber-frozen-shoulder.webp",
    imageAlt: "Physiotherapeut mobilisiert die Schulter eines Patienten",
    tags: ["Schulter"],
  },
  {
    title: "Tennisarm — Ursachen, Behandlung & Übungen",
    excerpt: "Warum Schonung beim Tennisarm schadet und exzentrisches Training der Gold-Standard ist.",
    slug: "tennisarm-epicondylitis-behandlung",
    date: "2026-03-09",
    image: "/images/ratgeber-tennisarm.webp",
    imageAlt: "Person hält sich den schmerzenden Ellenbogen",
    tags: ["Ellenbogen"],
  },
  {
    title: "Hüftschmerzen — Ursachen & Übungen",
    excerpt: "Hüftschmerzen verstehen: Häufige Ursachen, 3 Übungen die helfen und wann Sie zum Therapeuten sollten.",
    slug: "hueftschmerzen-ursachen-uebungen",
