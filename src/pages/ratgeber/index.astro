---

<Base title="Ratgeber Physiotherapie | Tipps & Wissen | Physio One Lübeck" description="Ratgeber rund um Physiotherapie, Rückenschmerzen, Rehabilitation und Prävention. Expertenwissen von Ihrem Therapeuten-Team in Lübeck.">
  <Header />

  <section class="section page-header">
    <div class="container">
      <h1>Ratgeber <span class="text-accent">Physiotherapie</span></h1>
      <p class="page-header__subtitle">Expertenwissen aus unserer Praxis — für Ihre Gesundheit.</p>
    </div>
  </section>

  <section class="section newsletter-section">
    <div class="container">
      <div class="newsletter-box">
        <div class="newsletter-box__content">
          <span class="newsletter-box__badge">Newsletter</span>
          <h2 class="newsletter-box__title">One Health Weekly</h2>
          <p class="newsletter-box__text">Jeden Donnerstag: Gesundheitstipps, Übungen und Wissenswertes rund um Physiotherapie — direkt in Ihr Postfach.</p>
        </div>
        <form class="newsletter-box__form" id="newsletter-form" action="https://sendfox.com/form/m279ry/m2jz0q" method="post" target="_blank">
          <div class="newsletter-box__inputs">
            <input type="text" name="first_name" placeholder="Vorname" class="newsletter-input" required />
            <input type="email" name="email" placeholder="E-Mail-Adresse" class="newsletter-input" required />
          </div>
          <button type="submit" class="newsletter-btn">Kostenlos anmelden</button>
          <p class="newsletter-box__hint">Abmeldung jederzeit möglich. <a href="/datenschutz/">Datenschutz</a></p>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="filter-bar" id="filter-bar">
        {tags.map(tag => (
          <button class={`filter-tag ${tag === 'Alle' ? 'filter-tag--active' : ''}`} data-tag={tag}>{tag}</button>
        ))}
      </div>

      <div class="articles-grid" id="articles-grid">
        {articles.map(a => (
          <a href={`/ratgeber/${a.slug}/`} class="article-card card" data-tags={a.tags.join(',')}>
            <div class="article-card__image">
              <img src={a.image} alt={a.imageAlt} width="600" height="338" loading="lazy" />
            </div>
            <div class="article-card__body">
              <div class="article-card__meta">
                <time class="article-card__date" datetime={a.date}>{new Date(a.date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
                <div class="article-card__tags">
                  {a.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <h2 class="article-card__title">{a.title}</h2>
              <p class="article-card__excerpt">{a.excerpt}</p>
              <span class="article-card__link">Weiterlesen &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.filter-tag');
    const cards = document.querySelectorAll('.article-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;

        buttons.forEach(b => b.classList.remove('filter-tag--active'));
        btn.classList.add('filter-tag--active');

        cards.forEach(card => {
          if (tag === 'Alle') {
            card.style.display = '';
          } else {
            const cardTags = card.dataset.tags.split(',');
            card.style.display = cardTags.includes(tag) ? '' : 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-2xl));
    padding-bottom: var(--space-xl);
    background: var(--color-black);
    color: var(--color-white);
  }

  .page-header h1 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .page-header .text-accent {
    color: var(--color-accent);
  }

  .page-header__subtitle {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-lg);
    max-width: 600px;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
  }

  .filter-tag {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-mid-gray, #ddd);
    border-radius: 100px;
    background: transparent;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-tag--active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .article-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .article-card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-lg, 12px) var(--radius-lg, 12px) 0 0;
    margin: calc(-1 * var(--space-md)) calc(-1 * var(--space-md)) 0;
  }

  .article-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .article-card:hover .article-card__image img {
    transform: scale(1.05);
  }

  .article-card__body {
    padding-top: var(--space-md);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .article-card__date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-card__tags {
    display: flex;
    gap: 0.25rem;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    background: rgba(234, 93, 28, 0.1);
    color: var(--color-accent);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-card__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-xs);
    line-height: 1.2;
  }

  .article-card__excerpt {
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-muted);
    flex-grow: 1;
    font-size: var(--text-sm);
  }

  .article-card__link {
    font-family: var(--font-headline);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-top: var(--space-sm);
  }

  .article-card:hover .article-card__link {
    color: var(--color-accent-hover);
  }

  @media (max-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Newsletter Section */
  .newsletter-section {
    padding-top: var(--space-lg);
    padding-bottom: 0;
  }

  .newsletter-box {
    background: var(--color-black);
    border-radius: var(--radius-lg, 12px);
    padding: var(--space-xl) var(--space-2xl);
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
    color: var(--color-white);
  }

  .newsletter-box__content {
    flex: 1;
    min-width: 280px;
  }

  .newsletter-box__badge {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(234, 93, 28, 0.15);
    color: var(--color-accent);
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .newsletter-box__title {
    font-family: var(--font-headline);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--color-white);
    margin-bottom: var(--space-xs);
    line-height: 1.1;
  }

  .newsletter-box__text {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 300;
    font-size: var(--text-base);
    line-height: 1.6;
    margin: 0;
  }

  .newsletter-box__form {
    flex: 1;
    min-width: 300px;
  }

  .newsletter-box__inputs {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .newsletter-input {
    flex: 1;
    padding: 0.85rem 1rem;
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: var(--text-base, 1rem);
    transition: border-color 0.2s ease;
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.75);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .newsletter-btn {
    width: 100%;
    padding: 0.85rem 2rem;
    font-family: var(--font-headline);
    font-size: var(--text-lg, 1.125rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent);
    color: var(--color-white);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .newsletter-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .newsletter-box__hint {
    margin-top: var(--space-xs);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.75);
    text-align: center;
  }

  .newsletter-box__hint a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .newsletter-box {
      flex-direction: column;
      padding: var(--space-lg);
      text-align: center;
    }

    .newsletter-box__inputs {
      flex-direction: column;
    }
  }
</style>
