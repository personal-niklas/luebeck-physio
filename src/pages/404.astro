---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base title="Seite nicht gefunden | Physio One Lübeck" description="Seite nicht gefunden – Physio One Physiotherapie Lübeck." noindex={true}>
  <Header />

  <section class="section error-page">
    <div class="container error-page__container">
      <span class="error-page__code">404</span>
      <h1>Seite nicht gefunden</h1>
      <p class="error-page__text">
        Die Seite, die Sie suchen, existiert leider nicht oder wurde verschoben.
      </p>
      <a href="/" class="btn btn--primary error-page__cta">Zur&uuml;ck zur Startseite</a>
    </div>
  </section>

  <section class="section error-links">
    <div class="container">
      <h2 class="text-center">Beliebte Seiten</h2>
      <div class="error-cards">
        <a href="/leistungen/" class="error-card">
          <div class="error-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div>
            <h3>Leistungen</h3>
            <p>Physiotherapie, Lymphdrainage, Fango &amp; mehr</p>
          </div>
        </a>
        <a href="/termin/" class="error-card">
          <div class="error-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div>
            <h3>Termin buchen</h3>
            <p>Online, telefonisch oder per WhatsApp</p>
          </div>
        </a>
        <a href="/team/" class="error-card">
          <div class="error-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <h3>Unser Team</h3>
            <p>Lernen Sie unsere Therapeuten kennen</p>
          </div>
        </a>
        <a href="/kontakt/" class="error-card">
          <div class="error-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h3>Kontakt &amp; Anfahrt</h3>
            <p>So finden Sie uns in L&uuml;beck</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .error-page {
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
    background: var(--color-black);
    color: var(--color-white);
    text-align: center;
  }

  .error-page__container {
    max-width: 600px;
  }

  .error-page__code {
    display: block;
    font-family: var(--font-headline);
    font-size: clamp(6rem, 15vw, 12rem);
    color: var(--color-accent);
    line-height: 1;
    opacity: 0.25;
    margin-bottom: var(--space-sm);
  }

  .error-page h1 {
    color: var(--color-white);
    margin-bottom: var(--space-md);
  }

  .error-page__text {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-lg);
    font-weight: 300;
    margin-bottom: var(--space-xl);
  }

  .error-page__cta {
    font-size: var(--text-lg);
    padding: var(--space-sm) var(--space-xl);
  }

  /* Popular Links */
  .error-links {
    padding: var(--space-3xl) 0;
  }

  .error-links h2 {
    margin-bottom: var(--space-xl);
  }

  .error-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 800px;
    margin: 0 auto;
  }

  .error-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-mid-gray);
    border-radius: var(--border-radius);
    text-decoration: none;
    color: var(--color-text-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .error-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--color-accent);
  }

  .error-card__icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(234, 93, 28, 0.08);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-card h3 {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-primary);
    margin-bottom: 2px;
  }

  .error-card p {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .error-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
