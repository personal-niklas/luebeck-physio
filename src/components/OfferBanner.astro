---
/**
 * OfferBanner — Rotating urgency banner with countdown timer.
 * Adapted for luebeck-physio.de (Physio One).
 */
---

<div class="offer-banner" id="offer-banner" role="complementary" aria-label="Aktuelle Aktion">
  <div class="offer-banner__inner container">
    <span class="offer-banner__emoji" id="offer-emoji"></span>
    <span class="offer-banner__text" id="offer-text"></span>
    <a href="https://www.doctolib.de/praxis/luebeck/physio-one-luebeck" target="_blank" rel="noopener" class="offer-banner__cta" id="offer-cta">Termin buchen</a>
    <button class="offer-banner__close" id="offer-close" aria-label="Banner schließen" type="button">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</div>

<style>
  .offer-banner {
    background: linear-gradient(90deg, #1a1a1a 0%, #111 50%, #1a1a1a 100%);
    color: #ffffff;
    padding: 0.6rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1001;
    overflow: hidden;
    /* CLS fix: start hidden without transform to avoid layout shift */
    display: none;
  }

  .offer-banner.active {
    display: block;
  }

  .offer-banner.dismissed {
    display: none;
    pointer-events: none;
  }

  .offer-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    flex-wrap: nowrap;
  }

  .offer-banner__emoji { font-size: 1rem; flex-shrink: 0; }

  .offer-banner__text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .offer-banner__cta {
    display: inline-block;
    background: #ea5d1c;
    color: #ffffff;
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .offer-banner__cta:hover {
    background: #d4521a;
    transform: scale(1.04);
    color: #ffffff;
  }

  .offer-banner__close {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    padding: 0.75rem;
    line-height: 0;
    transition: color 0.2s;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .offer-banner__close:hover { color: #ffffff; }

  .offer-banner::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(234, 93, 28, 0.06), transparent);
    animation: offerShimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes offerShimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* Reduced motion: no shimmer */
  @media (prefers-reduced-motion: reduce) {
    .offer-banner::after { animation: none; }
  }

  @media (max-width: 768px) {
    .offer-banner__inner {
      font-size: 0.6875rem;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: center;
      padding-right: 2rem;
    }
    .offer-banner__text {
      white-space: normal;
      text-align: center;
      flex-basis: 100%;
    }
    .offer-banner__countdown { order: -1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .offer-banner::after { animation: none; }
  }
</style>

<script is:inline>
  (function() {
    var banner = document.getElementById('offer-banner');
    if (!banner) return;

    try {
      var dismissed = localStorage.getItem('po-offer-dismissed');
      if (dismissed && Date.now() - parseInt(dismissed, 10) < 86400000) {
        document.documentElement.style.setProperty('--banner-height', '0px');
        banner.classList.add('dismissed');
        return;
      }
    } catch(e) {}

    var day = new Date().getDate();
    var doctolib = 'https://www.doctolib.de/praxis/luebeck/physio-one-luebeck';

    // 3 rotating CTAs based on day of month
    var offer;
    if (day <= 10) {
      offer = { text: 'Schmerzen? Wir helfen \u2014 oft noch diese Woche Termine frei', cta: 'Jetzt buchen', emoji: '\uD83D\uDC4B' };
    } else if (day <= 20) {
      offer = { text: 'Rezept vom Arzt? Direkt online Termin sichern \u2014 ohne Wartezeit', cta: 'Termin buchen', emoji: '\u2705' };
    } else {
      offer = { text: 'Physiotherapie + Training unter einem Dach \u2014 starte jetzt', cta: 'Termin buchen', emoji: '\uD83C\uDFE5' };
    }

    document.getElementById('offer-emoji').textContent = offer.emoji;
    document.getElementById('offer-text').textContent = offer.text;
    var ctaEl = document.getElementById('offer-cta');
    ctaEl.textContent = offer.cta;
    ctaEl.href = doctolib;

    banner.classList.add('active');

    // CLS fix: measure height after display:block, set CSS var once
    var bannerH = banner.offsetHeight;
    document.documentElement.style.setProperty('--banner-height', bannerH + 'px');

    function hideBanner() {
      banner.classList.remove('active');
      banner.classList.add('dismissed');
      document.documentElement.style.setProperty('--banner-height', '0px');
    }

    document.getElementById('offer-close').addEventListener('click', function() {
      hideBanner();
      try { localStorage.setItem('po-offer-dismissed', String(Date.now())); } catch(e) {}
    });
  })();
</script>
