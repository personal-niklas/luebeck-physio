---
/**
 * OfferBanner — Rotating urgency banner with countdown timer.
 * Adapted for luebeck-physio.de (Physio One).
 */
---

<div class="offer-banner" id="offer-banner" role="complementary" aria-label="Aktuelle Aktion">
  <div class="offer-banner__inner container">
    <span class="offer-banner__emoji" id="offer-emoji"></span>
    <span class="offer-banner__text" id="offer-text"></span>
    <span class="offer-banner__countdown" id="offer-countdown">
      <span class="offer-banner__cd-item"><span id="cd-days">0</span><small>T</small></span>
      <span class="offer-banner__cd-sep">:</span>
      <span class="offer-banner__cd-item"><span id="cd-hours">0</span><small>Std</small></span>
      <span class="offer-banner__cd-sep">:</span>
      <span class="offer-banner__cd-item"><span id="cd-mins">0</span><small>Min</small></span>
    </span>
    <a href="https://www.doctolib.de/praxis/luebeck/physio-one-luebeck" target="_blank" rel="noopener" class="offer-banner__cta" id="offer-cta">Termin buchen</a>
    <button class="offer-banner__close" id="offer-close" aria-label="Banner schließen" type="button">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</div>

<style>
  .offer-banner {
    background: linear-gradient(90deg, #1a1a1a 0%, #111 50%, #1a1a1a 100%);
    color: #ffffff;
    padding: 0.6rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1001;
    overflow: hidden;
    display: none;
  }

  .offer-banner.active {
    display: block;
    animation: offerSlideDown 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes offerSlideDown {
    from { transform: translateY(-100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .offer-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    flex-wrap: nowrap;
  }

  .offer-banner__emoji { font-size: 1rem; flex-shrink: 0; }

  .offer-banner__text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .offer-banner__countdown {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .offer-banner__cd-item {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
    background: rgba(234, 93, 28, 0.2);
    padding: 0.15rem 0.375rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
  }

  .offer-banner__cd-item small {
    font-size: 0.5625rem;
    font-weight: 400;
    opacity: 0.7;
    text-transform: uppercase;
  }

  .offer-banner__cd-sep { opacity: 0.4; font-weight: 300; font-size: 0.75rem; }

  .offer-banner__cta {
    display: inline-block;
    background: #ea5d1c;
    color: #ffffff;
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .offer-banner__cta:hover {
    background: #d4521a;
    transform: scale(1.04);
    color: #ffffff;
  }

  .offer-banner__close {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 0.25rem;
    line-height: 0;
    transition: color 0.2s;
  }

  .offer-banner__close:hover { color: #ffffff; }

  .offer-banner::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(234, 93, 28, 0.06), transparent);
    animation: offerShimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes offerShimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  @media (max-width: 768px) {
    .offer-banner__inner {
      font-size: 0.6875rem;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: center;
      padding-right: 2rem;
    }
    .offer-banner__text {
      white-space: normal;
      text-align: center;
      flex-basis: 100%;
    }
    .offer-banner__countdown { order: -1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .offer-banner::after { animation: none; }
    .offer-banner.active { animation: none; }
  }
</style>

<script is:inline>
  (function() {
    var banner = document.getElementById('offer-banner');
    if (!banner) return;

    var dismissed = localStorage.getItem('po-offer-dismissed');
    if (dismissed && Date.now() - parseInt(dismissed, 10) < 86400000) return;

    var now = new Date();
    var day = now.getDate();
    var month = now.getMonth();
    var year = now.getFullYear();

    var offer, deadline;
    var doctolib = 'https://www.doctolib.de/praxis/luebeck/physio-one-luebeck';
    if (day <= 15) {
      offer = { text: 'Jetzt Termin buchen: Kurze Wartezeiten dank flexibler Terminvergabe', cta: 'Termin buchen', emoji: '\u2705', href: doctolib };
      deadline = new Date(year, month, 15, 23, 59, 59);
    } else {
      offer = { text: 'Noch freie Termine diese Woche: Jetzt online bei Doctolib buchen', cta: 'Jetzt buchen', emoji: '\uD83D\uDCC5', href: doctolib };
      deadline = new Date(year, month + 1, 0, 23, 59, 59);
    }

    document.getElementById('offer-emoji').textContent = offer.emoji;
    document.getElementById('offer-text').textContent = offer.text;
    var ctaEl = document.getElementById('offer-cta');
    ctaEl.textContent = offer.cta;
    ctaEl.href = offer.href;

    function updateCountdown() {
      var diff = deadline.getTime() - Date.now();
      if (diff <= 0) { banner.style.display = 'none'; return; }
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      document.getElementById('cd-days').textContent = d;
      document.getElementById('cd-hours').textContent = h < 10 ? '0' + h : h;
      document.getElementById('cd-mins').textContent = m < 10 ? '0' + m : m;
    }

    updateCountdown();
    setInterval(updateCountdown, 60000);

    banner.classList.add('active');

    requestAnimationFrame(function() {
      var bannerH = banner.offsetHeight;
      document.documentElement.style.setProperty('--banner-height', bannerH + 'px');
    });

    function hideBanner() {
      banner.classList.remove('active');
      banner.style.display = 'none';
      document.documentElement.style.setProperty('--banner-height', '0px');
    }

    document.getElementById('offer-close').addEventListener('click', function() {
      hideBanner();
      localStorage.setItem('po-offer-dismissed', String(Date.now()));
    });
  })();
</script>
