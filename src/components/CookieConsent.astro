---
/**
 * DSGVO-konformer Cookie-Banner mit Google Consent Mode V2
 *
 * Architektur:
 * 1. Consent Default Script setzt alle Signale auf 'denied' (in Base.astro <head>)
 * 2. GTM lädt immer (in Base.astro) — Consent Mode V2 steuert was passiert
 * 3. Cookie-Banner zeigt sich dem User
 * 4. Nach Consent: Signale auf 'granted' → volles Tracking mit Cookies
 * 5. Ohne Consent: Cookieless Pings (keine Cookies, keine personenbezogenen Daten, DSGVO-konform)
 *
 * Cloudflare Web Analytics braucht KEINEN Consent (cookie-free, DSGVO-konform)
 */
---

<script>
  // Lazy-load CookieConsent after page is interactive (reduces TBT)
  async function initCookieConsent() {
    await import('vanilla-cookieconsent/dist/cookieconsent.css');
    const CookieConsent = await import('vanilla-cookieconsent');

    /**
     * Google Consent Mode V2 Signale updaten
     * GTM lädt immer (in Base.astro) — hier werden nur die Consent-Signale gesteuert
     */
    function updateConsentSignals(granted: boolean) {
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) { window.dataLayer.push(arguments); }

      if (granted) {
        gtag('consent', 'update', {
          'ad_storage': 'granted',
          'analytics_storage': 'granted',
          'ad_user_data': 'granted',
          'ad_personalization': 'granted',
        });
      } else {
        gtag('consent', 'update', {
          'ad_storage': 'denied',
          'analytics_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
        });
      }
    }

    CookieConsent.run({
      guiOptions: {
        consentModal: {
          layout: 'box inline',
          position: 'bottom left',
        },
        preferencesModal: {
          layout: 'box',
        },
      },

      categories: {
        necessary: {
          enabled: true,
          readOnly: true,
        },
        analytics: {
          autoClear: {
            cookies: [
              { name: /^_ga/ },
              { name: '_gid' },
            ],
          },
        },
        marketing: {
          autoClear: {
            cookies: [
              { name: /^_gc/ },
              { name: '_fbp' },
            ],
          },
        },
      },

      onFirstConsent: ({ cookie }) => {
        const granted = cookie.categories.includes('analytics') || cookie.categories.includes('marketing');
        updateConsentSignals(granted);
      },

      onChange: ({ cookie }) => {
        const granted = cookie.categories.includes('analytics') || cookie.categories.includes('marketing');
        updateConsentSignals(granted);
      },

      onConsent: ({ cookie }) => {
        const granted = cookie.categories.includes('analytics') || cookie.categories.includes('marketing');
        updateConsentSignals(granted);
      },

      language: {
        default: 'de',
        translations: {
          de: {
            consentModal: {
              title: 'Wir respektieren Ihre Privatsphäre',
              description: 'Wir nutzen Cookies für Analyse (Google Analytics via GTM) und Marketing (Google Ads). Cloudflare Web Analytics läuft ohne Cookies und ist immer aktiv. <a href="/datenschutz/" class="cc-link">Mehr erfahren</a>',
              acceptAllBtn: 'Alle akzeptieren',
              acceptNecessaryBtn: 'Nur notwendige',
              showPreferencesBtn: 'Einstellungen',
            },
            preferencesModal: {
              title: 'Cookie-Einstellungen',
              acceptAllBtn: 'Alle akzeptieren',
              acceptNecessaryBtn: 'Nur notwendige',
              savePreferencesBtn: 'Auswahl speichern',
              sections: [
                {
                  title: 'Cookie-Nutzung',
                  description: 'Wir verwenden Cookies, um Ihnen die bestmögliche Erfahrung zu bieten. Sie können selbst entscheiden, welche Kategorien Sie zulassen möchten.',
                },
                {
                  title: 'Notwendige Cookies',
                  description: 'Diese Cookies sind für die Grundfunktionen der Website erforderlich und können nicht deaktiviert werden.',
                  linkedCategory: 'necessary',
                },
                {
                  title: 'Analyse-Cookies',
                  description: 'Helfen uns zu verstehen, wie Besucher unsere Website nutzen. Die Daten werden anonymisiert erhoben (Google Analytics via GTM).',
                  linkedCategory: 'analytics',
                },
                {
                  title: 'Marketing-Cookies',
                  description: 'Werden verwendet, um Werbung relevanter zu gestalten und die Wirksamkeit von Kampagnen zu messen (Google Ads).',
                  linkedCategory: 'marketing',
                },
                {
                  title: 'Weitere Informationen',
                  description: 'Bei Fragen kontaktieren Sie uns unter <a class="cc-link" href="mailto:info@luebeck-physio.de">info@luebeck-physio.de</a>. Datenschutzerklärung <a class="cc-link" href="/datenschutz/">hier</a>.',
                },
              ],
            },
          },
        },
      },
    });
  } // end initCookieConsent

  // Defer cookie consent initialization to reduce TBT
  if (document.readyState === 'complete') {
    setTimeout(initCookieConsent, 0);
  } else {
    window.addEventListener('load', () => setTimeout(initCookieConsent, 0));
  }
</script>

