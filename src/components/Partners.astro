---
/**
 * Referenzen – dezente Kundenleiste als Social Proof
 */

const clients = [
  "Telekom",
  "Hansestadt Lübeck",
  "Colibri",
  "Colibris Eyewear",
  "Hansa-Baubeschlag",
  "PVZ Pressevertriebszentrale",
];
---

<div class="partners">
  <div class="container">
    <p class="partners__label">Arbeiten mit uns zusammen oder haben bereits mit uns gearbeitet</p>
    <div class="partners__list">
      {clients.map((name) => (
        <span class="partners__name">{name}</span>
      ))}
      <span class="partners__sep">u.a.</span>
    </div>
  </div>
</div>

<style>
  .partners {
    padding: var(--space-md) 0;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  .partners__label {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: 0;
  }

  .partners__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.25rem var(--space-md);
  }

  .partners__name {
    font-size: var(--text-sm);
    color: rgba(0, 0, 0, 0.55);
    font-weight: 400;
    white-space: nowrap;
  }

  .partners__sep {
    font-size: var(--text-xs);
    color: rgba(0, 0, 0, 0.45);
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .partners__list {
      gap: 0.125rem var(--space-sm);
    }

    .partners__name {
      font-size: var(--text-xs);
    }
  }
</style>
