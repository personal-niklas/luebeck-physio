---
/**
 * Referenzen – durchlaufende Logo-Leiste als Social Proof
 * Infinite marquee with grayscale partner logos
 */

const partners = [
  { name: "Telekom", logo: "/images/partners/telekom.svg" },
  { name: "Hansestadt Lübeck", logo: "/images/partners/hansestadt-luebeck.svg" },
  { name: "Colibri", logo: "/images/partners/colibri.svg" },
  { name: "Colibris Eyewear", logo: "/images/partners/colibris-eyewear.svg" },
  { name: "Hansa-Baubeschlag", logo: "/images/partners/hansa-baubeschlag.svg" },
  { name: "PVZ Pressevertriebszentrale", logo: "/images/partners/pvz.svg" },
  { name: "Ex-Rohr", logo: "/images/partners/exrohr.svg" },
];
---

<div class="partners">
  <p class="partners__label">Arbeiten mit uns zusammen oder haben bereits mit uns gearbeitet</p>
  <div class="partners__track">
    <div class="partners__scroll">
      {partners.map((p) => (
        <div class="partners__item">
          <img src={p.logo} alt={p.name} loading="lazy" />
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {partners.map((p) => (
        <div class="partners__item" aria-hidden="true">
          <img src={p.logo} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .partners {
    padding: var(--space-md) 0;
    overflow: hidden;
  }

  .partners__label {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: 0 0 var(--space-sm);
    text-align: center;
  }

  .partners__track {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .partners__scroll {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    width: max-content;
    animation: scroll 30s linear infinite;
  }

  .partners__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 36px;
  }

  .partners__item img {
    height: 100%;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.45;
    transition: opacity 0.3s ease, filter 0.3s ease;
  }

  .partners__scroll:hover {
    animation-play-state: paused;
  }

  .partners__scroll:hover .partners__item img {
    opacity: 0.35;
  }

  .partners__item:hover img {
    opacity: 0.7 !important;
    filter: grayscale(60%);
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .partners__item {
      height: 28px;
    }

    .partners__item img {
      max-width: 120px;
    }

    .partners__scroll {
      gap: var(--space-lg);
      animation-duration: 25s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .partners__scroll {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
    }

    .partners__track {
      mask-image: none;
      -webkit-mask-image: none;
    }

    .partners__item[aria-hidden="true"] {
      display: none;
    }
  }
</style>
