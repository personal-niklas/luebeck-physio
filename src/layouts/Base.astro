---
import CookieConsent from '../components/CookieConsent.astro';
import OfferBanner from '../components/OfferBanner.astro';
import ExitIntent from '../components/ExitIntent.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Physio One – Ihre Physiotherapie in Lübeck. Krankengymnastik, KGG, Lymphdrainage, Fango & mehr. Alle Kassen. Jetzt Termin buchen!",
  ogImage = "https://luebeck-physio.de/images/og-image.jpg",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Breadcrumb generation
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbLabels: Record<string, string> = {
  'leistungen': 'Leistungen',
  'krankengymnastik-luebeck': 'Krankengymnastik',
  'geraetegestuetzte-krankengymnastik-luebeck': 'Gerätegestützte KG',
  'manuelle-lymphdrainage-luebeck': 'Manuelle Lymphdrainage',
  'fango-waermetherapie-luebeck': 'Fango & Wärmetherapie',
  'elektrotherapie-luebeck': 'Elektrotherapie',
  'massage-luebeck': 'Massage',
  'team': 'Team',
  'kontakt': 'Kontakt',
  'faq': 'FAQ',
  'b2b': 'Für Unternehmen',
  'krankenkassen': 'Krankenkassen',
  'ratgeber': 'Ratgeber',
  'rueckenschmerzen-uebungen-physiotherapie': 'Rückenschmerzen',
  'kreuzband-op-rehabilitation-training': 'Kreuzband-Reha',
  'nackenverspannungen-bueroarbeit-tipps': 'Nackenverspannungen',
  'knieschmerzen-uebungen-physiotherapie': 'Knieschmerzen',
  'spannungskopfschmerzen-physiotherapie': 'Spannungskopfschmerzen',
  'spondylolisthesis-uebungen': 'Spondylolisthesis',
  'morgens-rueckenschmerzen-uebungen': 'Morgens Rückenschmerzen',
  'bandscheibenvorfall-symptome-behandlung': 'Bandscheibenvorfall',
  'isg-blockade-uebungen-behandlung': 'ISG-Blockade',
  'frozen-shoulder-behandlung-uebungen': 'Frozen Shoulder',
  'tennisarm-epicondylitis-behandlung': 'Tennisarm',
  'hueftschmerzen-ursachen-uebungen': 'Hüftschmerzen',
  'impressum': 'Impressum',
  'datenschutz': 'Datenschutz',
  'danke': 'Vielen Dank',
  'fragebogen': 'Behandlungs-Check',
  'karriere': 'Karriere',
  'termin': 'Termin',
  'chat': 'Chat',
};

const breadcrumbs = [
  { name: 'Startseite', url: new URL('/', Astro.site).href },
  ...pathSegments.map((segment, i) => ({
    name: breadcrumbLabels[segment] || segment,
    url: new URL(`/${pathSegments.slice(0, i + 1).join('/')}/`, Astro.site).href,
  })),
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- CLS fix: set banner height before first paint -->
    <script is:inline>
      (function(){try{var d=localStorage.getItem('po-offer-dismissed');if(d&&Date.now()-parseInt(d,10)<864e5){document.documentElement.style.setProperty('--banner-height','0px')}}catch(e){}})();
    </script>
    <meta name="description" content={description} />
    <meta name="author" content="Physio One" />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
    <link rel="alternate" hreflang="de" href={canonicalURL} />

    <!-- Preconnect: Cloudflare Analytics -->
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />

    <!-- Font Preload (self-hosted, DSGVO-konform) -->
    <link rel="preload" href="/fonts/bebas-neue-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Physio One Lübeck" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Consent Mode V2 – Default: alles verweigert (DSGVO) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('consent', 'default', {
        'ad_storage': 'denied',
        'analytics_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'wait_for_update': 500
      });
      gtag('set', 'ads_data_redaction', true);
    </script>

    <!-- GTM: defer load until idle to reduce TBT & unused JS -->
    <script is:inline>
      (function(){
        function loadGTM(){
          if(window.__gtmLoaded)return;window.__gtmLoaded=true;
          var w=window,d=document,l='dataLayer',i='GTM-NRMXS648';
          w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
          var f=d.getElementsByTagName('script')[0],j=d.createElement('script');
          j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i;
          f.parentNode.insertBefore(j,f);
        }
        if('requestIdleCallback' in window){requestIdleCallback(loadGTM,{timeout:3500})}
        else{setTimeout(loadGTM,3500)}
      })();
    </script>

    <!-- Google Ads (AW-11509829919) wird über GTM geladen — kein separates Tag nötig -->

    <!-- Structured Data: MedicalBusiness -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": ["Physiotherapist", "LocalBusiness", "MedicalBusiness"],
        "name": "Physio One – Physiotherapie Lübeck",
        "description": "Physiotherapie-Praxis in der Lübecker Innenstadt. Krankengymnastik, KG am Gerät, Sportphysiotherapie, Lymphdrainage und mehr.",
        "url": "https://luebeck-physio.de",
        "telephone": "+4945116086640",
        "email": "info@luebeck-physio.de",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Mengstraße 40",
          "addressLocality": "Lübeck",
          "postalCode": "23552",
          "addressCountry": "DE"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 53.8655,
          "longitude": 10.6866
        },
        "image": "https://luebeck-physio.de/logo.svg",
        "sameAs": [
          "https://www.doctolib.de/praxis/luebeck/physio-one",
          "https://niklaspape.de",
          "https://personaltrainingluebeck.de"
        ],
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "07:30",
            "closes": "19:00"
          }
        ],
        "priceRange": "$$",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5.0",
          "reviewCount": "35",
          "bestRating": "5"
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Behandlungen",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Krankengymnastik",
                "description": "Gezielte Bewegungstherapie bei Rückenschmerzen, Nackenverspannungen und Haltungsproblemen in Lübeck"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Gerätegestützte Krankengymnastik (KGG)",
                "description": "Training an medizinischen Geräten nach Verletzungen oder Operationen"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Manuelle Lymphdrainage",
                "description": "Sanfte Entstauungstherapie bei Lymphödemen und Schwellungen"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Fango & Wärmetherapie",
                "description": "Wärmebehandlung zur Schmerzlinderung und Muskelentspannung"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Elektrotherapie",
                "description": "Stromtherapie zur Schmerzlinderung und Muskelstimulation"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Klassische Massagetherapie",
                "description": "Therapeutische Massage zur Lösung von Verspannungen und Förderung der Durchblutung"
              }
            }
          ]
        }
      }
    </script>

    {pathSegments.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": crumb.name,
          "item": crumb.url
        }))
      })} />
    )}

    <slot name="head" />

    <title>{title}</title>
  </head>
  <body>
    <!-- GTM noscript fallback -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NRMXS648" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <OfferBanner />
    <main id="main">
      <slot />
    </main>
    <ExitIntent />

    <!-- Cookie Consent Banner (DSGVO + Google Consent Mode V2) -->
    <CookieConsent />

    <!-- STICKY CTA BAR (Mobile) -->
    <div class="sticky-cta-bar" id="stickyCta">
      <div class="sticky-cta-bar__inner">
        <span class="sticky-cta-bar__text">
          <strong>Termin vereinbaren</strong>
          Jetzt online buchen
        </span>
        <a href="https://www.doctolib.de/praxis/luebeck/physio-one" target="_blank" rel="noopener noreferrer" class="sticky-cta-bar__btn">
          Termin
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- DOCTOLIB FLOATING WIDGET (site-wide) -->
    <nav class="doctolib-widget" aria-label="Doctolib Schnellzugriff">
      <img src="/images/doctolib-white-transparent.webp" alt="Doctolib" width="100" height="20" loading="lazy" />
      <a href="https://www.doctolib.de/praxis/luebeck/physio-one?utm_campaign=website-button&utm_source=online-booking&utm_medium=referral" target="_blank" rel="noopener noreferrer">Termin</a>
      <a href="https://www.doctolib.de/praxis/luebeck/physio-one/patient-request?utm_campaign=website-button&utm_source=patient-messaging&utm_medium=referral" target="_blank" rel="noopener noreferrer">Nachricht</a>
    </nav>
    <style>
      .doctolib-widget {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 100;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--color-black, #000);
        padding: 0.625rem 1.25rem;
        border-radius: 100px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      }
      .doctolib-widget img {
        height: 16px;
        width: auto;
        opacity: 0.7;
      }
      .doctolib-widget a {
        color: var(--color-white, #fff);
        font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
        font-size: var(--text-sm, 0.875rem);
        font-weight: 600;
        text-decoration: none;
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        transition: background 0.15s;
      }
      .doctolib-widget a:first-of-type {
        background: var(--color-accent, #ea5d1c);
      }
      .doctolib-widget a:first-of-type:hover {
        background: var(--color-accent-hover, #d14e15);
        color: var(--color-white, #fff);
      }
      .doctolib-widget a:last-of-type:hover {
        background: rgba(255, 255, 255, 0.1);
        color: var(--color-white, #fff);
      }
      @media (max-width: 480px) {
        .doctolib-widget {
          right: 1rem;
          bottom: 1rem;
          gap: 0.5rem;
          padding: 0.5rem 1rem;
        }
        .doctolib-widget img {
          height: 14px;
        }
        .doctolib-widget a {
          font-size: 0.8125rem;
          padding: 0.3rem 0.6rem;
        }
      }
    </style>

    <!-- Scroll-Reveal Animations -->
    <script is:inline>
      (function(){
        var staggers = document.querySelectorAll('.stagger-in');
        if(!('IntersectionObserver' in window)) {
          staggers.forEach(function(el){ el.classList.add('visible'); });
          return;
        }
        var viewH = window.innerHeight;
        var obs = new IntersectionObserver(function(entries){
          entries.forEach(function(e){
            if(e.isIntersecting){
              if(e.target.classList.contains('stagger-in')) e.target.classList.add('visible');
              e.target.classList.add('reveal-animate');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.01, rootMargin: '0px 0px 50px 0px' });

        staggers.forEach(function(el){
          var rect = el.getBoundingClientRect();
          if(rect.top < viewH && rect.bottom > 0) {
            el.classList.add('visible');
            return;
          }
          obs.observe(el);
        });

        function forceShowAll() {
          document.querySelectorAll('.stagger-in:not(.visible)').forEach(function(el) {
            el.classList.add('visible');
          });
        }

        window.addEventListener('load', function() {
          var vH = window.innerHeight;
          document.querySelectorAll('.stagger-in:not(.visible)').forEach(function(el) {
            var r = el.getBoundingClientRect();
            if (r.top < vH && r.bottom > 0) el.classList.add('visible');
          });
        });

        // Fix bfcache: back-navigation restores page from cache without re-running JS
        window.addEventListener('pageshow', function(e) {
          if (e.persisted) {
            requestAnimationFrame(function() { forceShowAll(); });
          }
        });

        // Safari bfcache safety: visibilitychange catches cases persisted misses
        document.addEventListener('visibilitychange', function() {
          if (document.visibilityState === 'visible') {
            document.querySelectorAll('.stagger-in:not(.visible)').forEach(function(el) {
              var r = el.getBoundingClientRect();
              if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('visible');
            });
          }
        });
      })();
    </script>

    <script is:inline>
    (function(){
      var bar = document.getElementById('stickyCta');
      if (!bar || window.innerWidth > 768) return;
      var shown = false;
      window.addEventListener('scroll', function(){
        if (window.scrollY > 400 && !shown) {
          bar.classList.add('visible');
          shown = true;
        } else if (window.scrollY <= 400 && shown) {
          bar.classList.remove('visible');
          shown = false;
        }
      }, {passive: true});
    })();
    </script>

    <!-- Cloudflare Web Analytics (DSGVO-konform, cookie-free, kein Consent nötig) -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "678094f717df4789b600a3624ae3461b"}' is:inline></script>
  </body>
</html>
